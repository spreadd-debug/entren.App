
# Supabase Configuration
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key

# App Configuration
PORT=3000
NODE_ENV=development

# WhatsApp Cloud API (Meta) — required for Pro/Business automatic reminders
# Get these from https://developers.facebook.com/apps → WhatsApp → API Setup
WHATSAPP_ACCESS_TOKEN=your_permanent_access_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id

# Cron job secret — protects the /api/automation/cron endpoint
# Generate with: openssl rand -hex 32
CRON_SECRET=your_cron_secret

# Superadmin bypass credentials (frontend only, never commit real values)
VITE_SUPERADMIN_USER=your_superadmin_username
VITE_SUPERADMIN_PASS=your_superadmin_password

# Capacitor — URL base de la API para builds nativos (iOS/Android)
# Debe apuntar a tu deployment de Vercel
VITE_API_URL=https://tu-app.vercel.app
