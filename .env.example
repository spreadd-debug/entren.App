
# Supabase Configuration
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key

# App Configuration
PORT=3000
NODE_ENV=development

# WhatsApp Cloud API (Meta) — required for Pro/Business automatic reminders
# Get these from https://developers.facebook.com/apps → WhatsApp → API Setup
WHATSAPP_ACCESS_TOKEN=your_permanent_access_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id

# Cron job secret — protects the /api/automation/cron endpoint
# Generate with: openssl rand -hex 32
CRON_SECRET=your_cron_secret

# Superadmin bypass credentials (frontend only, never commit real values)
VITE_SUPERADMIN_USER=your_superadmin_username
VITE_SUPERADMIN_PASS=your_superadmin_password

# Capacitor — URL base de la API para builds nativos (iOS/Android)
# Debe apuntar a tu deployment de Vercel
VITE_API_URL=https://tu-app.vercel.app

# Strava integration — auto-import de corridas (Fase 2 atletas híbridos)
# Crear app en https://www.strava.com/settings/api
#   - Authorization Callback Domain: entren.app (sin scheme)
#   - Scopes solicitados: read, activity:read
STRAVA_CLIENT_ID=your_strava_client_id
STRAVA_CLIENT_SECRET=your_strava_client_secret

# Token aleatorio para validar el handshake del webhook con Strava
# Generar con: openssl rand -hex 16
STRAVA_WEBHOOK_VERIFY_TOKEN=your_random_webhook_token

# Secret HMAC para firmar el state del OAuth (anti-CSRF). Distinto del verify_token.
# Generar con: openssl rand -hex 32
STRAVA_OAUTH_STATE_SECRET=your_random_oauth_state_secret

# URL pública del callback (Strava redirige aquí post-autorización)
STRAVA_REDIRECT_URI=https://entren.app/api/strava/callback

# URL pública del portal (para el redirect post-callback al SPA)
PORTAL_PUBLIC_URL=https://entren.app
